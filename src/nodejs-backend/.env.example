# Optional: enable PostgreSQL persistence (omit all of these to use in-memory dev mode).
# DATABASE_URL=postgresql://postgres:secret@127.0.0.1:5432/mountain_explorers

# Or use discrete variables:
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=mountain_explorers
# DB_USER=postgres
# DB_PASSWORD=your_password

# APP_ADMIN_TOKEN=dev-admin
# PORT=4944

# Signing key for admin and traveler email/password JWTs (set a long random string in production).
# ADMIN_JWT_SECRET=

# Optional: disable “any II user is admin” when using dev-admin token (forces password JWT or real II admin role).
# TOURIST_DISABLE_OPEN_II_ADMIN=1

# When SMTP is off, also return OTP in JSON as devOtp (browser console can log it).
# Never enable in production unless you accept the risk. Requires SMTP unset (devMode).
# TOURIST_DEV_OTP_IN_RESPONSE=1

# Admin registration OTP email (omit SMTP_HOST to log OTP to server console in dev).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Mountain Explorers <noreply@example.com>"

# Full demo catalog → Postgres (same data as admin “Replace with demo catalog”):
#   npm run db:seed-demo
# Idempotent seed only when catalog is empty:
#   npm run db:seed-demo-if-empty
