{
  "name": "travelverse-3d",
  "type": "module",
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=7.0.0",
    "npm": "please use pnpm"
  },
  "scripts": {
    "dev": "npx --yes pnpm@9 --filter travelverse-3d-frontend run dev",
    "dev:api": "npx --yes pnpm@9 --filter tourist-node-api run dev",
    "server": "npx --yes pnpm@9 --filter travelverse-3d-frontend run dev",
    "sync-assets": "node scripts/sync-frontend-public-assets.js",
    "sync-backend-candid": "node scripts/sync-backend-candid.mjs",
    "fonts:decode": "node scripts/decode-base64-fonts.js",
    "images:decode": "node scripts/decode-base64-images.js",
    "build": "npx --yes pnpm@9 -r --if-present run build",
    "typecheck": "npx --yes pnpm@9 -r --if-present run typecheck",
    "check": "npx --yes pnpm@9 -r --if-present run check",
    "fix": "npx --yes pnpm@9 -r --if-present run fix"
  },
  "devDependencies": {
    "sharp": "^0.34.4"
  }
}
